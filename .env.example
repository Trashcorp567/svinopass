DATABASE_URL=postgresql://svinopass:svinopass@localhost:5432/svinopass
REDIS_URL=redis://localhost:6379/0
ENV=development
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","https://svinopass.ru"]

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=http://localhost:3000/payment/success
YOOKASSA_MOCK=true

# Yandex SMTP — enable mail clients in mailbox settings
# Option A: port 587 + STARTTLS
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=587
# SMTP_TLS=true
# SMTP_USE_SSL=false
# Option B: port 465 + SSL
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_TLS=false
SMTP_USE_SSL=true
SMTP_USER=you@yandex.ru
SMTP_PASSWORD=your-mailbox-or-app-password
SMTP_FROM=you@yandex.ru

# Email breach monitoring (Свиной сторож)
# leakcheck — free public API, no key (default, works from RU)
# hibp — needs paid HIBP API key
# mock — local dev without network
BREACH_PROVIDER=leakcheck
LEAKCHECK_API_KEY=
HIBP_API_KEY=

# Weekly watch cron (scripts/check_watch_subscriptions.py or POST /api/internal/watch/check)
WATCH_CRON_SECRET=
WATCH_CHECK_INTERVAL_DAYS=7

# На VPS reg.cloud SMTP-порты 465/587 заблокированы — используйте Yandex Cloud Postbox (HTTPS):
#
# EMAIL_PROVIDER=postbox
# SMTP_FROM=mail@svinopass.ru
# YANDEX_POSTBOX_ACCESS_KEY_ID=...
# YANDEX_POSTBOX_SECRET_ACCESS_KEY=...
#
# DNS в reg.ru (для DKIM Postbox):
# CNAME egt8f63fhemn5glq5kmb-1._domainkey -> egt8f63fhemn5glq5kmb-1.dkim.pstbx.ru
# CNAME egt8f63fhemn5glq5kmb-2._domainkey -> egt8f63fhemn5glq5kmb-2.dkim.pstbx.ru
# TXT @ -> v=spf1 include:spf.postbox.yandexcloud.net ~all